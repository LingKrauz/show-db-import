          "applicationInsightsName": "[coalesce(tryGet(if(parameters('enableMonitoring'), reference('monitoring'), null()), 'outputs', 'applicationInsightsName', 'value'), '')]",
          "applicationInsightsResourceId": "[coalesce(tryGet(if(parameters('enableMonitoring'), reference('monitoring'), null()), 'outputs', 'applicationInsightsId', 'value'), '')]",
          "logAnalyticsWorkspaceName": "[coalesce(tryGet(if(parameters('enableMonitoring'), reference('monitoring'), null()), 'outputs', 'logAnalyticsWorkspaceName', 'value'), '')]",
          "logAnalyticsWorkspaceResourceId": "[coalesce(tryGet(if(parameters('enableMonitoring'), reference('monitoring'), null()), 'outputs', 'logAnalyticsWorkspaceId', 'value'), '')]"
        },
        "portalLinks": {
          "appServicePlan": "[format('https://portal.azure.com/#resource{0}', reference('appServicePlan').outputs.id.value)]",
          "backendWebApp": "[format('https://portal.azure.com/#resource{0}', reference('webApp').outputs.id.value)]",
          "deployment": "[variables('deploymentPortalUrl')]",
          "resourceGroup": "[variables('resourceGroupPortalUrl')]",
          "staticWebApp": "[format('https://portal.azure.com/#resource{0}', reference('staticWebApp').outputs.id.value)]"
        },
        "resourceGroupName": "[resourceGroup().name]",
        "resourceIds": {
          "appServicePlan": "[reference('appServicePlan').outputs.id.value]",
          "applicationInsights": "[coalesce(tryGet(if(parameters('enableMonitoring'), reference('monitoring'), null()), 'outputs', 'applicationInsightsId', 'value'), '')]",
          "backendWebApp": "[reference('webApp').outputs.id.value]",
          "logAnalyticsWorkspace": "[coalesce(tryGet(if(parameters('enableMonitoring'), reference('monitoring'), null()), 'outputs', 'logAnalyticsWorkspaceId', 'value'), '')]",
          "staticWebApp": "[reference('staticWebApp').outputs.id.value]"
        },
        "staticWebApp": {
          "defaultHostname": "[reference('staticWebApp').outputs.defaultHostname.value]",
          "name": "[reference('staticWebApp').outputs.name.value]",
          "portalUrl": "[format('https://portal.azure.com/#resource{0}', reference('staticWebApp').outputs.id.value)]",
          "url": "[reference('staticWebApp').outputs.url.value]"
        }
      }
    }
  }
}